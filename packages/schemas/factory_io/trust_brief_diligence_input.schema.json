{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TrustBriefDiligenceFactoryInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["tenant_id", "organization_id", "submitted_by", "signal_payload"],
  "properties": {
    "tenant_id": { "type": "string", "format": "uuid" },
    "organization_id": { "type": "string", "format": "uuid" },
    "submitted_by": { "type": "string", "minLength": 1 },
    "source_request_id": { "type": "string" },
    "signal_payload": {
      "type": "object",
      "required": ["source", "summary"],
      "properties": {
        "source": { "enum": ["investor_diligence", "manual", "webhook"] },
        "summary": { "type": "string" },
        "target_name": { "type": "string" },
        "thesis": { "type": "string" }
      }
    },
    "source_entity_id": { "type": "string", "format": "uuid" },
    "target_entity_id": { "type": "string", "format": "uuid" }
  }
}
