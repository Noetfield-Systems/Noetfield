{
  "agent_id": "noetfield-copilot-governance",
  "version": "1.0.0",
  "display_name": "Copilot Governance Agent",
  "role": "copilot_assessment",
  "allowed_actions": [
    "evaluate_intent",
    "draft_tle",
    "surface_evidence_gaps",
    "recommend_policy_path"
