    "tenant_audit_read",
    "policy_pack_read",
    "purview_metadata_read",
    "entra_metadata_read"
  ],
  "approval_threshold": "single_human",
  "deny_tools_default": true,
  "prompt_template_ref": "docs/strategy/NOETFIELD_COPILOT_SME_SYSTEM_DESIGN_LOCKED_v1.md",
  "max_tool_calls_per_run": 12,
  "metadata": {
    "mode_sandbox": "observe",
    "mode_production": "enforce",
    "schema": "packages/schemas/agent-manifest.schema.json"
  }
}
